# Data directories
data/raw/*
data/interim/*
data/processed/*

# Keep folder placeholders
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Keep Python scripts in data folders
!data/raw/**/*.py
!data/interim/**/*.py
!data/processed/**/*.py
!data/raw/*.py
!data/interim/*.py
!data/processed/*.py

# Ignore CSV data files in data folders
data/raw/**/*.csv
data/interim/**/*.csv
data/processed/**/*.csv
data/raw/*.csv
data/interim/*.csv
data/processed/*.csv

# Model artifacts
models/*
!models/.gitkeep

# Outputs
outputs/figures/*
outputs/predictions/*
outputs/reports/*
!outputs/figures/.gitkeep
!outputs/predictions/.gitkeep
!outputs/reports/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/

# Pytest
.pytest_cache/

# Coverage
.coverage
htmlcov/